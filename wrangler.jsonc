{
  "name": "nilsbeerten-nl2",
  "main": "@astrojs/cloudflare/entrypoints/server",
  // Update to today's date
  // Set this to today's date
  "compatibility_date": "2026-03-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}