---
export interface Props {
    strokeWidth?: number;
    amplitude?: number;
    period?: number;
    class?: string;
}

/**
 * Generates an SVG path string for a mathematically correct sine wave
 * using cubic Bézier curves derived from the sine derivative.
 *
 * Function generated by Claude.
 *
 * @param cy         - Vertical centre of the wave in px
 * @param amplitude  - Peak deviation from centre in px
 * @param period     - Length of one full wave cycle in px
 * @param segments   - Cubic Bézier segments per period (must be even, ≥4)
 * @returns SVG path `d` attribute value
 */
function generateSineWavePath(
    cy: number,
    amplitude: number,
    period: number,
    segments: number = 8
): string {
    const segWidth = period / segments;
    const cpDx = segWidth / 3;

    const sineSlope = (x: number): number =>
        -amplitude * Math.cos((2 * Math.PI * x) / period) * ((2 * Math.PI) / period);

    let d = `M 0,${cy.toFixed(1)}`;
    let x = 0;

    while (x < period) {
        const x1 = Math.min(x + segWidth, period);
        const y0 = cy - amplitude * Math.sin((2 * Math.PI * x) / period);
        const y1 = cy - amplitude * Math.sin((2 * Math.PI * x1) / period);
        const s0 = sineSlope(x);
        const s1 = sineSlope(x1);

        const cp1x = x + cpDx;
        const cp1y = y0 + s0 * cpDx;
        const cp2x = x1 - cpDx;
        const cp2y = y1 - s1 * cpDx;

        d += ` C ${cp1x.toFixed(3)},${cp1y.toFixed(3)} ${cp2x.toFixed(3)},${cp2y.toFixed(3)} ${x1.toFixed(3)},${y1.toFixed(3)}`;
        x = x1;
    }

    return d;
}

/**
 * Generates an SVG data URI for a sine wave, ready for use as a CSS `url()` value.
 *
 * @param amplitude   - Peak deviation from centre in px
 * @param period      - Length of one full wave cycle in px
 * @param segments    - Cubic Bézier segments per period (must be even, ≥4)
 * @param strokeWidth - Width of the wave stroke in px
 * @returns A string ready for use as a CSS `url()` value
 */
function generateSineWaveUrl(
    amplitude: number,
    period: number,
    segments: number = 8,
    strokeWidth: number = 1.5
): string {
    // Add half the stroke width as padding on each side so the stroke isn't clipped
    const height = 2 * amplitude + strokeWidth;
    const cy = height / 2;
    const d = generateSineWavePath(cy, amplitude, period, segments);

    const svg = [
        `<svg xmlns='http://www.w3.org/2000/svg'`,
        ` width='${period}' height='${height}'`,
        ` viewBox='0 0 ${period} ${height}'>`,
        `<path d='${d}'`,
        ` stroke='white' stroke-width='${strokeWidth}'`,
        ` fill='none' stroke-linecap='square'/>`,
        `</svg>`,
    ].join("");

    const encoded = encodeURIComponent(svg).replace(/'/g, "%27").replace(/"/g, "%22");

    return `url("data:image/svg+xml,${encoded}")`;
}

const { class: className = "", strokeWidth = 2, amplitude = 3, period = 40 } = Astro.props;

const height = 2 * amplitude + strokeWidth * 2; // Double the stroke width as padding on each side to prevent clipping

const waveUrl = generateSineWaveUrl(amplitude, period, 8, strokeWidth);
---

<hr class={className} />

<style define:vars={{ waveUrl, height: `${height}px`, maskSize: `${period}px ${height}px` }}>
    hr {
        border: none;
        height: var(--height);
        background-color: var(--brand-hr);
        mask-image: var(--waveUrl);
        mask-repeat: repeat-x;
        mask-size: var(--maskSize);
        mask-position: center;
    }
</style>
